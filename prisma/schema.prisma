// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LookupKind {
  empresa
  unidade
  tipoAtividade
  servicoProduto
  escopo
  amostragem
  categoriaRegistro
  categoriaPlanilha
  tipoAtividadeGeral
  setorInterno
}

enum StatusConclusao {
  Pendente
  AguardandoRetornoInterno
  AguardandoRetornoCliente
  Concluido
}

enum Prioridade {
  Urgente
  Importante
  Medio
  Baixo
}

enum Role {
  ADMIN
  USER
}

enum VinculoTipo {
  atividade
  atividadeGeral
  registro
  planilha
}

model LookupItem {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      LookupKind
  name      String
  active    Boolean    @default(true)
  empresaId String?    // usado apenas por itens do tipo "unidade"
  cor       String?    // nome de token da paleta base (ex.: "base-1"), nunca hex livre
  ordem     Int        @default(0)
  createdAt DateTime   @default(now())

  @@index([userId, kind])
}

model Atividade {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresaId         String?
  unidadeId         String?
  assunto           String           @default("")
  tipoAtividadeIds  String[]
  emailConteudo     String           @default("")
  oportunidadeTexto String           @default("")
  contato           String           @default("")
  prazo             DateTime?
  prazoFim          DateTime?
  descricao         String           @default("")
  alinhamentos      String           @default("")
  status            StatusConclusao  @default(Pendente)
  prioridade        Prioridade       @default(Medio)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?
  concluidoEm       DateTime?        // setado pelo servidor ao entrar em status=Concluído, limpo ao sair
  /// coluna gerada (tsvector) criada via SQL raw na migration; Unsupported = Prisma não gerencia
  busca             Unsupported("tsvector")?

  propostas Proposta[]
  checklist ChecklistItem[]
  links     Link[]
  anexos    Anexo[]
  historico Historico[]

  @@index([userId])
  @@index([deletedAt])
  @@index([userId, empresaId])
  @@index([userId, unidadeId])
  @@index([userId, status])
  @@index([userId, prioridade])
  @@index([userId, prazo])
}

// Lista de links de uma atividade (quantidade ilimitada, spec 5.12). Mesmo
// padrão de Proposta/ChecklistItem: sub-tabela substituída inteira a cada
// save (deleteMany + create na mesma transação).
model Link {
  id          String    @id @default(cuid())
  atividadeId String
  atividade   Atividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  titulo      String    @default("")
  url         String
  ordem       Int       @default(0)

  @@index([atividadeId])
}

// Arquivo anexado a uma atividade. O binário fica em disco (volume do
// Railway, ver UPLOAD_DIR em src/lib/anexos.ts) — aqui só o metadado.
model Anexo {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  atividadeId    String
  atividade      Atividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  nomeOriginal   String
  nomeArmazenado String    @unique
  mimeType       String
  tamanho        Int
  createdAt      DateTime  @default(now())

  @@index([atividadeId])
}

// Log de auditoria de alteração de status/prazo/prioridade de uma atividade
// (critério de aceite da S6). Fica fora do include padrão de GET
// /api/atividades — cresce sem limite, é buscado sob demanda.
model Historico {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  atividadeId   String
  atividade     Atividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  campo         String
  valorAnterior String?
  valorNovo     String?
  createdAt     DateTime  @default(now())

  @@index([atividadeId, createdAt])
}

model Proposta {
  id                String    @id @default(cuid())
  atividadeId       String
  atividade         Atividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  numero            Int
  servicoProdutoIds String[]
  escopoIds         String[]
  amostragemIds     String[]
  quantidade        Float?
  valorUnitario     Float?
  valorTotal        Float?
  tipo              String?
  detalhe           String           @default("")
  observacao        String           @default("")
  prazoInicio       DateTime?
  prazoFim          DateTime?
  statusNegociacao  String?

  @@index([atividadeId])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  atividadeId String
  atividade   Atividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  texto       String
  concluido   Boolean   @default(false)
  ordem       Int       @default(0)
  prazo       DateTime?
  parentId    String?
  parent      ChecklistItem?  @relation("ChecklistSubitems", fields: [parentId], references: [id], onDelete: Cascade)
  subitems    ChecklistItem[] @relation("ChecklistSubitems")

  @@index([atividadeId])
  @@index([parentId])
}

model ChecklistTemplate {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nome      String
  createdAt DateTime @default(now())

  itens ChecklistTemplateItem[]

  @@index([userId])
}

model ChecklistTemplateItem {
  id         String   @id @default(cuid())
  templateId String
  template   ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  texto      String
  ordem      Int      @default(0)
  parentId   String?
  parent     ChecklistTemplateItem? @relation("TemplateSubitems", fields: [parentId], references: [id], onDelete: Cascade)
  subitems   ChecklistTemplateItem[] @relation("TemplateSubitems")

  @@index([templateId])
  @@index([parentId])
}

model AtividadeGeral {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresaId   String?
  unidadeId   String?
  tipoIds     String[]
  assunto     String           @default("")
  vinculos    String           @default("")
  prazo       DateTime?
  descricao   String           @default("")
  status      String           @default("Pendente")
  prioridade  Prioridade       @default(Medio)
  setorIds    String[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  /// coluna gerada (tsvector) criada via SQL raw na migration; Unsupported = Prisma não gerencia
  busca       Unsupported("tsvector")?

  checklist ChecklistGeralItem[]

  @@index([userId])
  @@index([userId, empresaId])
  @@index([userId, status])
  @@index([userId, prazo])
}

model ChecklistGeralItem {
  id                String           @id @default(cuid())
  atividadeGeralId  String
  atividadeGeral    AtividadeGeral   @relation(fields: [atividadeGeralId], references: [id], onDelete: Cascade)
  parentId          String?
  texto             String
  status            String           @default("Pendente")
  prioridade        Prioridade       @default(Medio)
  prazo             DateTime?
  ordem             Int              @default(0)
  empresaId         String?
  unidadeId         String?

  @@index([atividadeGeralId])
}

model Registro {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  nome         String        @default("")
  empresaId    String?
  unidadeId    String?
  contato      String        @default("")
  assunto      String        @default("")
  categoriaIds String[]
  /// @deprecated legado pré-vínculo polimórfico (S1). Fonte de verdade agora é Vinculo. Não escrever mais aqui.
  atividadeId  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  /// coluna gerada (tsvector) criada via SQL raw na migration; Unsupported = Prisma não gerencia
  busca        Unsupported("tsvector")?

  tabs RegistroTab[]

  @@index([userId])
  @@index([deletedAt])
  @@index([userId, empresaId])
}

model RegistroTab {
  id         String   @id @default(cuid())
  registroId String
  registro   Registro @relation(fields: [registroId], references: [id], onDelete: Cascade)
  titulo     String
  conteudo   String   @default("")
  ordem      Int      @default(0)

  @@index([registroId])
}

model Planilha {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nome         String   @default("")
  empresaId    String?
  unidadeId    String?
  assunto      String   @default("")
  categoriaIds String[]
  /// @deprecated legado pré-vínculo polimórfico (S1). Fonte de verdade agora é Vinculo. Não escrever mais aqui.
  atividadeId  String?
  conteudo     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?
  /// coluna gerada (tsvector) criada via SQL raw na migration; Unsupported = Prisma não gerencia
  busca        Unsupported("tsvector")?

  @@index([userId])
  @@index([deletedAt])
  @@index([userId, empresaId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())

  lookupItems     LookupItem[]
  atividades      Atividade[]
  registros       Registro[]
  planilhas       Planilha[]
  atividadesGerais AtividadeGeral[]
  checklistTemplates ChecklistTemplate[]
  knowledgeChunks  KnowledgeChunk[]
  chatMessages     ChatMessage[]
  pendingDeletions PendingDeletion[]
  vinculos         Vinculo[]
  anexos           Anexo[]
  historico        Historico[]
  widgetPreferencias WidgetPreferencia[]
}

// Preferência de exibição de um widget do Dashboard (S8): ordem, visibilidade
// e tamanho, por usuário. widgetId é a chave lógica do widget (ver
// src/lib/dashboard-widgets.ts), não uma FK — widgets são definidos em código,
// não em banco.
model WidgetPreferencia {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  widgetId String
  ordem    Int     @default(0)
  visivel  Boolean @default(true)
  tamanho  String  @default("normal")

  @@unique([userId, widgetId])
  @@index([userId])
}

// Vínculo polimórfico único entre objetos do sistema. Substitui os FKs
// diretos (ex.: Registro.atividadeId) — nunca crie tabela de vínculo por
// par de tipos (regra 5 do CLAUDE.md). Toda escrita passa por
// src/lib/vinculos.ts::normalizarPar para colapsar A→B e B→A na mesma linha.
model Vinculo {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  origemTipo  VinculoTipo
  origemId    String
  destinoTipo VinculoTipo
  destinoId   String
  createdAt   DateTime    @default(now())

  @@unique([userId, origemTipo, origemId, destinoTipo, destinoId], name: "vinculo_par_unico")
  @@index([userId, origemTipo, origemId])
  @@index([userId, destinoTipo, destinoId])
}

model KnowledgeChunk {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceType String
  sourceId   String
  content    String
  embedding  Float[]
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([userId, sourceType, sourceId])
  @@index([userId, sourceType])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Tracks a chat-initiated deletion request that hasn't been confirmed yet.
// The model can only complete the deletion in a LATER chat turn (a different
// requestedInMessageId) than the one that created this record — this stops
// the LLM from registering the request and confirming it in the same turn,
// which would make "confirmado=true" a value the model can just assert.
model PendingDeletion {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityType           String
  entityId             String
  requestedInMessageId String
  createdAt            DateTime @default(now())
  expiresAt            DateTime

  @@unique([userId, entityType, entityId])
  @@index([userId])
}
