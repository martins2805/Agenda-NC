// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum LookupKind {
  empresa
  unidade
  assunto
  tipoAtividade
  servicoProduto
  escopo
  amostragem
  categoriaRegistro
  categoriaPlanilha
}

enum StatusConclusao {
  Pendente
  AguardandoRetornoInterno
  AguardandoRetornoCliente
  Concluido
}

enum Prioridade {
  Urgente
  Importante
  Medio
  Baixo
}

enum Role {
  ADMIN
  USER
}

model LookupItem {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      LookupKind
  name      String
  active    Boolean    @default(true)
  empresaId String?    // usado apenas por itens do tipo "unidade"
  createdAt DateTime   @default(now())

  @@index([userId, kind])
}

model Atividade {
  id                String           @id @default(cuid())
  userId            String
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresaId         String?
  unidadeId         String?
  assuntoId         String?
  tipoAtividadeIds  String[]
  emailConteudo     String           @default("")
  oportunidadeTexto String           @default("")
  contato           String           @default("")
  prazo             DateTime?
  descricao         String           @default("")
  alinhamentos      String           @default("")
  status            StatusConclusao  @default(Pendente)
  prioridade        Prioridade       @default(Medio)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  propostas Proposta[]
  checklist ChecklistItem[]

  @@index([userId])
}

model Proposta {
  id                String    @id @default(cuid())
  atividadeId       String
  atividade         Atividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  numero            Int
  servicoProdutoIds String[]
  escopoIds         String[]
  amostragemIds     String[]
  quantidade        Float?
  valorUnitario     Float?
  valorTotal        Float?

  @@index([atividadeId])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  atividadeId String
  atividade   Atividade @relation(fields: [atividadeId], references: [id], onDelete: Cascade)
  texto       String
  concluido   Boolean   @default(false)
  ordem       Int       @default(0)
  prazo       DateTime?

  @@index([atividadeId])
}

model Registro {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  empresaId    String?
  unidadeId    String?
  contato      String        @default("")
  assuntoId    String?
  categoriaIds String[]
  atividadeId  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tabs RegistroTab[]

  @@index([userId])
}

model RegistroTab {
  id         String   @id @default(cuid())
  registroId String
  registro   Registro @relation(fields: [registroId], references: [id], onDelete: Cascade)
  titulo     String
  conteudo   String   @default("")
  ordem      Int      @default(0)

  @@index([registroId])
}

model Planilha {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  nome         String   @default("")
  empresaId    String?
  unidadeId    String?
  assuntoId    String?
  categoriaIds String[]
  atividadeId  String?
  conteudo     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())

  lookupItems     LookupItem[]
  atividades      Atividade[]
  registros       Registro[]
  planilhas       Planilha[]
  knowledgeChunks  KnowledgeChunk[]
  chatMessages     ChatMessage[]
  pendingDeletions PendingDeletion[]
}

model KnowledgeChunk {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceType String
  sourceId   String
  content    String
  embedding  Float[]
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([userId, sourceType, sourceId])
  @@index([userId, sourceType])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Tracks a chat-initiated deletion request that hasn't been confirmed yet.
// The model can only complete the deletion in a LATER chat turn (a different
// requestedInMessageId) than the one that created this record — this stops
// the LLM from registering the request and confirming it in the same turn,
// which would make "confirmado=true" a value the model can just assert.
model PendingDeletion {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityType           String
  entityId             String
  requestedInMessageId String
  createdAt            DateTime @default(now())
  expiresAt            DateTime

  @@unique([userId, entityType, entityId])
  @@index([userId])
}
